---
import '../styles/global.css';

export interface Props {
  title: string;
  description?: string;
  type?: 'website' | 'article';
  image?: string;
  publishedTime?: string;
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = 'Catatan praktis tentang C# modern dan agentic coding, dalam Bahasa Indonesia.',
  type = 'website',
  image,
  publishedTime,
  jsonLd,
} = Astro.props;

const tahun = new Date().getFullYear();

const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image ? new URL(image, Astro.site).href : undefined;
---

<!doctype html>
<html lang="id">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="C# Indonesia" />
    <meta property="og:locale" content="id_ID" />
    {ogImage && <meta property="og:image" content={ogImage} />}
    {publishedTime && <meta property="article:published_time" content={publishedTime} />}

    <!-- Twitter -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-top">
      <div class="wrap top-inner">
        <a class="brand" href="/" aria-label="C# Indonesia — beranda">
          <span class="brand-mark">C#</span>
          <span class="brand-name">C# Indonesia</span>
        </a>
        <nav class="top-links" aria-label="Tautan">
          <a href="https://ahmadilham.dev">Portfolio</a>
        </nav>
      </div>
    </header>

    <slot />

    <footer class="site-foot">
      <div class="wrap foot-inner">
        <span class="foot-mark">C#</span>
        <p class="foot-meta">
          C# Indonesia &middot; catatan C# modern &amp; agentic coding &middot; {tahun}
        </p>
        <nav class="foot-links" aria-label="Tautan">
          <a href="https://archive.csharp-indonesia.com">Arsip</a>
          <a href="https://github.com/ahmadilham">GitHub</a>
          <a href="https://ahmadilham.dev">Portfolio</a>
        </nav>
      </div>
    </footer>

    <style>
      .site-top {
        border-bottom: 1px solid var(--hair);
        padding: 0.9rem 0;
      }
      .top-inner {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }
      .brand { display: inline-flex; align-items: center; gap: 0.6rem; color: var(--ink); }
      .brand:hover { text-decoration: none; }
      .brand:hover .brand-name { color: var(--violet); }
      .brand-mark {
        font-family: var(--mono);
        font-weight: 600;
        font-size: 0.8rem;
        letter-spacing: 0.03em;
        color: var(--bg);
        background: var(--violet);
        border-radius: 4px;
        padding: 0.15rem 0.45rem;
      }
      .brand-name {
        font-family: var(--mono);
        font-size: 0.85rem;
        font-weight: 500;
        transition: color 0.18s ease;
      }
      .top-links a {
        font-family: var(--mono);
        font-size: 0.76rem;
        color: var(--ink-soft);
      }
      .top-links a:hover { color: var(--violet); text-decoration: none; }

      .site-foot {
        border-top: 1px solid var(--hair);
        margin-top: 5rem;
        padding: 2rem 0 3rem;
      }
      .foot-inner {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        flex-wrap: wrap;
      }
      .foot-mark {
        font-family: var(--mono);
        font-weight: 600;
        font-size: 0.8rem;
        letter-spacing: 0.03em;
        color: var(--bg);
        background: var(--violet);
        border-radius: 4px;
        padding: 0.15rem 0.45rem;
      }
      .foot-meta {
        font-family: var(--mono);
        font-size: 0.76rem;
        color: var(--ink-faint);
        margin-right: auto;
      }
      .foot-links { display: flex; gap: 1.25rem; }
      .foot-links a {
        font-family: var(--mono);
        font-size: 0.76rem;
        color: var(--ink-soft);
      }
      .foot-links a:hover { color: var(--violet); text-decoration: none; }
      @media (max-width: 560px) {
        .foot-meta { margin-right: 0; width: 100%; order: 3; }
      }
    </style>
  </body>
</html>
